<!DOCTYPE html>
<html lang="fr" data-theme="warm">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="description" content="GestiLoc — Gestion locative privée LOKONON Paul"/>
<title>GestiLoc</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
/* ════════════════════════════════════════════════
   THEMES
   ════════════════════════════════════════════════ */
[data-theme="warm"] {
  --bg:       #f4f1eb;
  --bg1:      #edeae3;
  --bg2:      #e4e0d8;
  --surface:  rgba(255,255,255,0.82);
  --surface2: rgba(255,255,255,0.96);
  --border:   rgba(0,0,0,0.09);
  --border2:  rgba(0,0,0,0.15);
  --green:    #0d7344;
  --green-d:  rgba(13,115,68,0.12);
  --red:      #b83232;
  --red-d:    rgba(184,50,50,0.11);
  --amber:    #a85f08;
  --amber-d:  rgba(168,95,8,0.11);
  --blue:     #1655a0;
  --blue-d:   rgba(22,85,160,0.11);
  --text:     #1a1815;
  --text2:    #59534c;
  --text3:    #9c958d;
  --shadow:   rgba(0,0,0,0.08);
  --noise:    url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.022'/%3E%3C/svg%3E");
  --glow1:    rgba(13,115,68,0.05);
  --glow2:    rgba(22,85,160,0.04);
  --topbar-bg: rgba(244,241,235,0.92);
  --nav-bg:   rgba(244,241,235,0.95);
  --auth-bg:  rgba(255,253,249,0.94);
  --modal-bg: rgba(252,250,246,0.97);
  --input-bg: rgba(255,255,255,0.85);
}

[data-theme="frost"] {
  --bg:       #f0f4f8;
  --bg1:      #e8edf4;
  --bg2:      #dde4ee;
  --surface:  rgba(255,255,255,0.80);
  --surface2: rgba(255,255,255,0.96);
  --border:   rgba(22,85,160,0.10);
  --border2:  rgba(22,85,160,0.18);
  --green:    #0a6e42;
  --green-d:  rgba(10,110,66,0.11);
  --red:      #b02b2b;
  --red-d:    rgba(176,43,43,0.11);
  --amber:    #9a5a06;
  --amber-d:  rgba(154,90,6,0.11);
  --blue:     #1450a8;
  --blue-d:   rgba(20,80,168,0.12);
  --text:     #0f1520;
  --text2:    #4a5568;
  --text3:    #8fa0b8;
  --shadow:   rgba(20,80,168,0.08);
  --noise:    url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.018'/%3E%3C/svg%3E");
  --glow1:    rgba(20,80,168,0.06);
  --glow2:    rgba(10,110,66,0.04);
  --topbar-bg: rgba(240,244,248,0.93);
  --nav-bg:   rgba(240,244,248,0.96);
  --auth-bg:  rgba(248,250,255,0.95);
  --modal-bg: rgba(245,248,255,0.97);
  --input-bg: rgba(255,255,255,0.88);
}

/* ════════════════════════════════════════════════
   BASE
   ════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 16px; }

body {
  font-family: 'DM Sans', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}

body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: var(--noise);
  pointer-events: none; z-index: 0;
}

.ambient {
  position: fixed; border-radius: 50%;
  filter: blur(150px); pointer-events: none; z-index: 0;
}
.a1 { width: 60vw; height: 60vw; max-width: 700px; max-height: 700px;
  background: radial-gradient(circle, var(--glow1) 0%, transparent 70%);
  top: -20vw; left: -10vw; }
.a2 { width: 50vw; height: 50vw; max-width: 600px; max-height: 600px;
  background: radial-gradient(circle, var(--glow2) 0%, transparent 70%);
  bottom: -15vw; right: -10vw; }

/* ════════════════════════════════════════════════
   TYPOGRAPHY SCALE — readable on all screens
   ════════════════════════════════════════════════ */
:root {
  --fs-xs:   0.72rem;   /* 11.5px */
  --fs-sm:   0.8125rem; /* 13px   */
  --fs-base: 0.9375rem; /* 15px   */
  --fs-md:   1rem;      /* 16px   */
  --fs-lg:   1.125rem;  /* 18px   */
  --fs-xl:   1.375rem;  /* 22px   */
  --r:  12px;
  --r2: 8px;
  --r3: 20px;
  --mono: 'DM Mono', monospace;
  --serif: 'Cormorant Garamond', Georgia, serif;
}

/* ════════════════════════════════════════════════
   LAYOUT
   ════════════════════════════════════════════════ */
#app { position: relative; z-index: 1; display: flex; flex-direction: column; min-height: 100vh; }
#main { display: none; flex-direction: column; min-height: 100vh; padding-bottom: 72px; }
.content { padding: 1.25rem; flex: 1; max-width: 1100px; margin: 0 auto; width: 100%; }
.page { display: none; }
.page.active { display: block; animation: fadeUp .18s ease; }
@keyframes fadeUp { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:none; } }

/* ════════════════════════════════════════════════
   TOPBAR
   ════════════════════════════════════════════════ */
.topbar {
  background: var(--topbar-bg);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-bottom: 0.5px solid var(--border);
  padding: 0 1.25rem;
  height: 56px;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 30;
}
.topbar-brand { display: flex; align-items: center; gap: 10px; }
.topbar-logo {
  width: 32px; height: 32px; border-radius: 9px;
  background: var(--green);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 8px rgba(13,115,68,0.25);
}
.topbar-logo span { font-family: var(--mono); font-size: 11px; font-weight: 500; color: #fff; letter-spacing: 0.04em; }
.topbar-name { font-size: var(--fs-base); font-weight: 600; color: var(--text); letter-spacing: -0.01em; }
.topbar-role { font-size: var(--fs-xs); color: var(--green); font-weight: 500; }
.topbar-right { display: flex; align-items: center; gap: 8px; }
.topbar-date { font-size: var(--fs-xs); color: var(--text3); font-family: var(--mono); display: none; }
@media (min-width: 600px) { .topbar-date { display: block; } }

/* ════════════════════════════════════════════════
   BOTTOM NAV (mobile-first)
   ════════════════════════════════════════════════ */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 30;
  background: var(--nav-bg);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-top: 0.5px solid var(--border);
  display: flex; align-items: center;
  height: 72px;
  padding-bottom: env(safe-area-inset-bottom);
}
.nav-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 3px;
  padding: 8px 4px;
  font-size: 10px; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase;
  color: var(--text3);
  background: none; border: none; cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: color .15s;
  min-height: 44px;
}
.nav-item.active { color: var(--green); }
.nav-item svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
.nav-item.active svg { stroke-width: 2.2; }

/* Desktop: top nav instead */
@media (min-width: 800px) {
  .bottom-nav { display: none; }
  #main { padding-bottom: 0; }
  .top-nav {
    display: flex !important;
    background: var(--topbar-bg);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 0.5px solid var(--border);
    padding: 0 1.25rem; gap: 2px; overflow-x: auto;
  }
  .top-nav-btn {
    padding: 12px 14px; font-size: var(--fs-sm); font-weight: 500;
    background: none; border: none; border-bottom: 2px solid transparent;
    cursor: pointer; color: var(--text3); white-space: nowrap;
    font-family: 'DM Sans', sans-serif; transition: color .15s, border-color .15s;
  }
  .top-nav-btn.active { color: var(--green); border-bottom-color: var(--green); }
  .top-nav-btn:hover:not(.active) { color: var(--text2); }
}
.top-nav { display: none; }

/* ════════════════════════════════════════════════
   AUTH
   ════════════════════════════════════════════════ */
#auth-screen {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; position: relative; z-index: 1;
  padding: 1.25rem;
}
.auth-card {
  width: 100%; max-width: 380px;
  background: var(--auth-bg);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border: 0.5px solid var(--border2);
  border-radius: var(--r3); padding: 2.5rem 2rem; text-align: center;
  box-shadow: 0 20px 60px var(--shadow), 0 2px 8px var(--shadow);
}
.auth-logo {
  width: 64px; height: 64px; border-radius: 18px;
  background: var(--green); margin: 0 auto 1.25rem;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6px 20px rgba(13,115,68,0.28);
}
.auth-logo span { font-family: var(--mono); font-size: 16px; font-weight: 500; color: #fff; }
.auth-card h1 { font-size: var(--fs-xl); font-weight: 600; color: var(--text); letter-spacing: -0.02em; margin-bottom: 2px; }
.auth-sub { font-size: var(--fs-sm); color: var(--text3); margin-bottom: 3px; }
.auth-owner { font-size: var(--fs-sm); font-weight: 600; color: var(--green); margin-bottom: 1.75rem; }
.auth-input {
  width: 100%; padding: 13px 16px; font-size: var(--fs-base);
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid var(--border2); border-radius: var(--r2);
  background: var(--input-bg); color: var(--text);
  margin-bottom: 10px; transition: border-color .2s, box-shadow .2s;
  letter-spacing: 0.08em;
}
.auth-input:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 3px var(--green-d); }
.auth-input::placeholder { color: var(--text3); letter-spacing: 0; }
.auth-error { color: var(--red); font-size: var(--fs-sm); margin-top: 8px; display: none; }
.auth-hint { font-size: var(--fs-xs); color: var(--text3); margin-top: 10px; }

/* ════════════════════════════════════════════════
   BUTTONS
   ════════════════════════════════════════════════ */
.btn-primary {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  width: 100%; padding: 13px; font-size: var(--fs-base); font-weight: 600;
  font-family: 'DM Sans', sans-serif;
  background: var(--green); color: #fff; border: none;
  border-radius: var(--r2); cursor: pointer;
  box-shadow: 0 4px 16px rgba(13,115,68,0.25);
  transition: opacity .15s, transform .1s;
}
.btn-primary:hover { opacity: .9; }
.btn-primary:active { transform: scale(.99); }

.btn-sm {
  display: inline-flex; align-items: center; justify-content: center; gap: 5px;
  padding: 9px 14px; font-size: var(--fs-sm); font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid var(--border2); border-radius: var(--r2);
  background: var(--surface2); color: var(--text2); cursor: pointer;
  transition: background .15s, color .15s;
  white-space: nowrap; min-height: 36px;
}
.btn-sm:hover { background: #fff; color: var(--text); }

.btn-add {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 10px 16px; font-size: var(--fs-sm); font-weight: 600;
  font-family: 'DM Sans', sans-serif;
  background: var(--green); color: #fff; border: none;
  border-radius: var(--r2); cursor: pointer;
  box-shadow: 0 2px 10px rgba(13,115,68,0.22);
  transition: opacity .15s; white-space: nowrap; min-height: 40px;
}
.btn-add:hover { opacity: .88; }

.btn-danger {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 8px 13px; font-size: var(--fs-xs); font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid rgba(184,50,50,0.28); border-radius: var(--r2);
  background: var(--red-d); color: var(--red); cursor: pointer;
  transition: background .15s; min-height: 36px;
}
.btn-danger:hover { background: rgba(184,50,50,0.18); }

.btn-info {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 8px 13px; font-size: var(--fs-xs); font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid rgba(22,85,160,0.25); border-radius: var(--r2);
  background: var(--blue-d); color: var(--blue); cursor: pointer;
  transition: background .15s; min-height: 36px;
}
.btn-info:hover { background: rgba(22,85,160,0.18); }

.btn-edit {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 8px 13px; font-size: var(--fs-xs); font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid rgba(168,95,8,0.25); border-radius: var(--r2);
  background: var(--amber-d); color: var(--amber); cursor: pointer;
  transition: background .15s; min-height: 36px;
}
.btn-edit:hover { background: rgba(168,95,8,0.18); }

.btn-wa {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 8px 13px; font-size: var(--fs-xs); font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid rgba(37,211,102,0.3); border-radius: var(--r2);
  background: rgba(37,211,102,0.10); color: #1a7a3a; cursor: pointer;
  transition: background .15s; min-height: 36px;
}
.btn-wa:hover { background: rgba(37,211,102,0.20); }

.btn-ghost {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 9px 14px; font-size: var(--fs-sm); font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  border: 0.5px solid var(--border2); border-radius: var(--r2);
  background: var(--surface); color: var(--text2); cursor: pointer;
  transition: background .15s; min-height: 36px;
}
.btn-ghost:hover { background: var(--surface2); }

/* ════════════════════════════════════════════════
   CARDS & SURFACES
   ════════════════════════════════════════════════ */
.card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--r);
  box-shadow: 0 1px 4px var(--shadow);
  transition: border-color .2s, box-shadow .2s;
}
.card:hover { border-color: var(--border2); box-shadow: 0 3px 12px var(--shadow); }

.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1rem; flex-wrap: wrap; gap: 8px;
}
.section-title { font-size: var(--fs-md); font-weight: 600; color: var(--text); letter-spacing: -0.01em; }
.section-right { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

/* ════════════════════════════════════════════════
   STATS GRID
   ════════════════════════════════════════════════ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px; margin-bottom: 1.25rem;
}
@media (min-width: 500px) { .stats-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 800px) { .stats-grid { grid-template-columns: repeat(6, 1fr); } }

.stat-card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--r); padding: .9rem 1rem;
  box-shadow: 0 1px 4px var(--shadow);
}
.stat-label { font-size: var(--fs-xs); color: var(--text3); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 7px; }
.stat-value { font-size: 1.5rem; font-weight: 600; color: var(--text); font-family: var(--mono); letter-spacing: -0.02em; line-height: 1; }
.stat-value.g { color: var(--green); }
.stat-value.r { color: var(--red); }
.stat-value.b { color: var(--blue); }
.stat-value.a { color: var(--amber); }
.stat-sub { font-size: var(--fs-xs); color: var(--text3); margin-top: 4px; }

/* ════════════════════════════════════════════════
   TABLE
   ════════════════════════════════════════════════ */
.table-wrap {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--r);
  overflow: hidden; overflow-x: auto;
  box-shadow: 0 1px 4px var(--shadow);
}
table { width: 100%; border-collapse: collapse; font-size: var(--fs-sm); min-width: 480px; }
thead th {
  padding: 10px 14px; text-align: left; font-weight: 600;
  color: var(--text3); font-size: var(--fs-xs); text-transform: uppercase;
  letter-spacing: .07em; background: rgba(0,0,0,0.025);
  border-bottom: 0.5px solid var(--border); white-space: nowrap;
}
tbody td { padding: 12px 14px; color: var(--text); border-bottom: 0.5px solid var(--border); vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover td { background: rgba(0,0,0,0.02); }
.empty-state { padding: 2.5rem; text-align: center; color: var(--text3); font-size: var(--fs-sm); }

/* ════════════════════════════════════════════════
   BADGES
   ════════════════════════════════════════════════ */
.badge {
  display: inline-block; padding: 3px 9px;
  border-radius: 20px; font-size: var(--fs-xs); font-weight: 600; letter-spacing: .03em; white-space: nowrap;
}
.b-ok  { background: var(--green-d); color: var(--green); border: 0.5px solid rgba(13,115,68,.2); }
.b-att { background: var(--amber-d); color: var(--amber); border: 0.5px solid rgba(168,95,8,.2); }
.b-ko  { background: var(--red-d);   color: var(--red);   border: 0.5px solid rgba(184,50,50,.2); }
.b-free{ background: var(--blue-d);  color: var(--blue);  border: 0.5px solid rgba(22,85,160,.2); }
.b-occ { background: var(--amber-d); color: var(--amber); border: 0.5px solid rgba(168,95,8,.2); }

/* ════════════════════════════════════════════════
   ALERT BANNERS
   ════════════════════════════════════════════════ */
.alert { padding: 11px 14px; border-radius: var(--r2); font-size: var(--fs-sm); margin-bottom: 1rem; }
.alert-red  { background: var(--red-d);   border: 0.5px solid rgba(184,50,50,.25); color: var(--red); }
.alert-amber{ background: var(--amber-d); border: 0.5px solid rgba(168,95,8,.25);  color: var(--amber); }
.alert strong { font-weight: 600; }

/* ════════════════════════════════════════════════
   MODAL
   ════════════════════════════════════════════════ */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.45);
  backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
  align-items: center; justify-content: center; z-index: 100; padding: 1rem;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--modal-bg);
  border: 0.5px solid var(--border2); border-radius: var(--r3);
  padding: 1.5rem; width: 500px; max-width: 98vw;
  max-height: 92vh; overflow-y: auto;
  box-shadow: 0 24px 60px rgba(0,0,0,.14), 0 4px 16px rgba(0,0,0,.08);
}
.modal h2 { font-size: var(--fs-md); font-weight: 600; margin-bottom: 1.25rem; color: var(--text); letter-spacing: -.01em; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 1.25rem; flex-wrap: wrap; }

/* Form */
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
@media (max-width: 440px) { .form-row { grid-template-columns: 1fr; } }
.form-group { margin-bottom: 10px; }
.form-group label { display: block; font-size: var(--fs-xs); color: var(--text3); margin-bottom: 5px; text-transform: uppercase; letter-spacing: .07em; font-weight: 600; }
.form-group input, .form-group select, .form-group textarea {
  width: 100%; padding: 11px 13px; font-size: var(--fs-sm);
  border: 0.5px solid var(--border2); border-radius: var(--r2);
  background: var(--input-bg); color: var(--text);
  font-family: 'DM Sans', sans-serif;
  transition: border-color .2s, box-shadow .2s;
}
.form-group select option { background: #fff; color: #111; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  outline: none; border-color: var(--green); box-shadow: 0 0 0 3px var(--green-d);
}
.form-group input::placeholder { color: var(--text3); }

/* ════════════════════════════════════════════════
   CHAMBRES GRID
   ════════════════════════════════════════════════ */
.chambres-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}
.chambre-card {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: var(--r); padding: 1.1rem;
  box-shadow: 0 1px 4px var(--shadow);
  transition: border-color .2s, box-shadow .2s;
}
.chambre-card:hover { border-color: var(--border2); box-shadow: 0 3px 12px var(--shadow); }
.chambre-num { font-size: var(--fs-md); font-weight: 600; color: var(--text); margin-bottom: 2px; }
.chambre-type { font-size: var(--fs-xs); color: var(--text3); margin-bottom: 8px; }
.chambre-price { font-size: var(--fs-sm); font-weight: 600; color: var(--green); font-family: var(--mono); margin-top: 8px; }
.chambre-caution { font-size: var(--fs-xs); color: var(--text3); margin-top: 2px; font-family: var(--mono); }
.chambre-tenant { font-size: var(--fs-xs); color: var(--text2); margin-top: 5px; }
.chambre-actions { display: flex; gap: 6px; margin-top: 10px; flex-wrap: wrap; }

/* ════════════════════════════════════════════════
   HISTORIQUE
   ════════════════════════════════════════════════ */
.hist-select {
  padding: 10px 13px; font-size: var(--fs-sm);
  border: 0.5px solid var(--border2); border-radius: var(--r2);
  background: #fff; color: var(--text);
  font-family: 'DM Sans', sans-serif; min-width: 220px;
  cursor: pointer;
}
.hist-select:focus { outline: none; border-color: var(--green); }

.loc-info-card {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: var(--r); padding: 1rem 1.2rem; margin-bottom: 1rem;
  display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px;
  box-shadow: 0 1px 4px var(--shadow);
}
.li-label { color: var(--text3); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .07em; font-weight: 600; }
.li-val { font-weight: 600; color: var(--text); font-size: var(--fs-sm); margin-top: 3px; }

/* ════════════════════════════════════════════════
   RAPPORT
   ════════════════════════════════════════════════ */
.rapport-section {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: var(--r); padding: 1.2rem; margin-bottom: 1rem;
  box-shadow: 0 1px 4px var(--shadow);
}
.rapport-section h3 {
  font-size: var(--fs-xs); font-weight: 600; color: var(--text3);
  text-transform: uppercase; letter-spacing: .07em;
  margin-bottom: 1rem; padding-bottom: 8px; border-bottom: 0.5px solid var(--border);
}
.rapport-row {
  display: flex; justify-content: space-between; align-items: center;
  font-size: var(--fs-sm); padding: 7px 0; border-bottom: 0.5px solid var(--border);
}
.rapport-row:last-child { border-bottom: none; }
.rapport-row.total { font-weight: 600; font-size: var(--fs-base); padding-top: 10px; border-top: 0.5px solid var(--border2); margin-top: 4px; }
.rapport-label { color: var(--text2); }
.rapport-val { font-weight: 600; color: var(--text); font-family: var(--mono); }
.rapport-val.g { color: var(--green); }
.rapport-val.r { color: var(--red); }
.rapport-val.a { color: var(--amber); }

/* ════════════════════════════════════════════════
   RELANCES
   ════════════════════════════════════════════════ */
.relance-card {
  background: var(--surface); border: 0.5px solid rgba(184,50,50,.2);
  border-radius: var(--r2); padding: 13px 16px; margin-bottom: 8px;
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 8px; box-shadow: 0 1px 4px var(--shadow);
}
.relance-nom { font-size: var(--fs-sm); font-weight: 600; color: var(--text); }
.relance-detail { font-size: var(--fs-xs); color: var(--text3); margin-top: 2px; }

/* ════════════════════════════════════════════════
   PARAMETRES
   ════════════════════════════════════════════════ */
.param-section {
  background: var(--surface); border: 0.5px solid var(--border);
  border-radius: var(--r); padding: 1.25rem; margin-bottom: 1rem;
  box-shadow: 0 1px 4px var(--shadow);
}
.param-title { font-size: var(--fs-xs); font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 1rem; }
.param-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: 12px; }
.param-desc { font-size: var(--fs-sm); color: var(--text); font-weight: 500; }
.param-sub { font-size: var(--fs-xs); color: var(--text3); margin-top: 2px; }

/* Theme toggle pills */
.theme-toggle { display: flex; gap: 8px; flex-wrap: wrap; }
.theme-pill {
  padding: 8px 16px; border-radius: 20px; font-size: var(--fs-sm); font-weight: 500;
  border: 1.5px solid var(--border2); background: var(--surface2);
  cursor: pointer; font-family: 'DM Sans', sans-serif; color: var(--text2);
  transition: all .15s;
}
.theme-pill.active { border-color: var(--green); color: var(--green); background: var(--green-d); font-weight: 600; }

/* Divider */
.divider { border: none; border-top: 0.5px solid var(--border); margin: 1rem 0; }

/* ════════════════════════════════════════════════
   QUITTANCE — ecran
   ════════════════════════════════════════════════ */
.quittance-wrap {
  background: #fff; color: #1a1a2e;
  font-family: 'DM Sans', sans-serif;
  border-radius: var(--r); overflow: hidden;
  margin-top: 1rem; box-shadow: 0 8px 40px rgba(0,0,0,.18);
}
.qt-band {
  background: #1a2d22;
  padding: 24px 28px 20px;
  display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
}
.qt-owner-name { font-size: 17px; font-weight: 600; color: #fff; letter-spacing: -.01em; margin-bottom: 2px; }
.qt-owner-role { font-size: 10px; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .12em; }
.qt-owner-addr { font-size: 11px; color: rgba(255,255,255,.6); margin-top: 5px; }
.qt-doc-label { font-size: 9px; color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .14em; margin-bottom: 3px; text-align: right; }
.qt-doc-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 21px; font-weight: 500; color: #fff; font-style: italic; line-height: 1.2; text-align: right; }
.qt-ref { font-family: 'DM Mono', monospace; font-size: 10px; color: rgba(34,201,125,.85); margin-top: 5px; text-align: right; }
.qt-body { padding: 22px 28px; background: #fff; }
.qt-section-label { font-size: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: .15em; color: #0d7344; margin-bottom: 8px; }
.qt-locataire-block { border: 1px solid #e0ece0; border-radius: 7px; padding: 12px 16px; margin-bottom: 16px; background: #fafcfa; }
.qt-loc-name { font-size: 16px; font-weight: 600; color: #111; margin-bottom: 4px; }
.qt-loc-meta { font-size: 12px; color: #666; display: flex; gap: 14px; flex-wrap: wrap; }
.qt-details-grid { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid #e8ece8; border-radius: 7px; overflow: hidden; margin-bottom: 16px; }
.qt-detail-cell { padding: 10px 14px; border-bottom: 1px solid #f0f0f0; border-right: 1px solid #f0f0f0; }
.qt-detail-cell:nth-child(even) { border-right: none; }
.qt-detail-cell:nth-last-child(-n+2) { border-bottom: none; }
.qt-detail-key { font-size: 8px; text-transform: uppercase; letter-spacing: .1em; color: #999; margin-bottom: 3px; }
.qt-detail-val { font-size: 13px; font-weight: 600; color: #222; }
.qt-montant-block { background: #f0f9f4; border: 1px solid #c0e0d0; border-radius: 7px; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.qt-montant-label { font-size: 11px; color: #2a6644; font-weight: 500; }
.qt-montant-val { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 26px; font-weight: 600; color: #1a6640; letter-spacing: -.02em; }
.qt-montant-cur { font-size: 12px; color: #2a6644; margin-left: 5px; }
.qt-signatures { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 16px; }
.qt-sig-box { border-top: 1px solid #ddd; padding-top: 8px; }
.qt-sig-label { font-size: 9px; text-transform: uppercase; letter-spacing: .1em; color: #aaa; margin-bottom: 28px; }
.qt-sig-name { font-size: 11px; color: #444; }
.qt-footer { border-top: 1px solid #f0f0f0; padding-top: 12px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 6px; }
.qt-footer-left { font-size: 9px; color: #bbb; }
.qt-footer-badge { font-family: 'DM Mono', monospace; font-size: 8px; color: #0d7344; background: #f0f9f4; border: 1px solid #c0e0d0; border-radius: 4px; padding: 2px 7px; }

/* ════════════════════════════════════════════════
   PRINT — supprime tout sauf la quittance/rapport
   ════════════════════════════════════════════════ */
@media print {
  body * { visibility: hidden; }
  #print-frame { visibility: visible; position: fixed; inset: 0; width: 100%; height: 100%; border: none; }
}

/* ════════════════════════════════════════════════
   SCROLLBAR
   ════════════════════════════════════════════════ */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

/* ════════════════════════════════════════════════
   RESPONSIVE EXTRAS
   ════════════════════════════════════════════════ */
@media (max-width: 600px) {
  .content { padding: 1rem; }
  .stat-value { font-size: 1.3rem; }
  .hide-mobile { display: none !important; }
  .actions-wrap { flex-direction: column; align-items: stretch; }
  .actions-wrap .btn-sm, .actions-wrap .btn-danger, .actions-wrap .btn-info, .actions-wrap .btn-edit, .actions-wrap .btn-wa { justify-content: center; }
}
</style>
