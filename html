// ── DASHBOARD ─────────────────────────────────────────────────────
function renderDashboard() {
  const m=mNow(), today=new Date().toISOString().split('T')[0];
  const occIds=[...new Set(S.locataires.map(l=>l.chambreId))].filter(id=>S.chambres.find(c=>c.id==id));
  const nbOcc=occIds.length, total=S.chambres.length;
  const psM=S.paiements.filter(p=>p.mois===m);
  const impayes=psM.filter(p=>p.statut==='impaye');
  const attente=psM.filter(p=>p.statut==='en_attente');
  const recettes=psM.filter(p=>p.statut==='paye').reduce((s,p)=>s+p.montant,0);
  const attendu=S.locataires.reduce((s,l)=>{ const c=cById(l.chambreId); return s+(c?c.prix:0); },0);
  const taux=attendu>0?Math.round((recettes/attendu)*100):0;

  document.getElementById('stats-grid').innerHTML = [
    ['Chambres','--',total,''],
    ['Occupées','g',nbOcc,''],
    ['Libres','b',total-nbOcc,''],
    ['Impayés ce mois','r',impayes.length,''],
    ['Recettes du mois','g',fFCFA(recettes),'FCFA'],
    ['Recouvrement','${taux>=80?"g":taux>=50?"a":"r"}',taux+'%',''],
  ].map(([label,cls,val,sub],i)=>`<div class="stat-card">
    <div class="stat-label">${label}</div>
    <div class="stat-value ${i===5?(taux>=80?'g':taux>=50?'a':'r'):cls}">${val}</div>
    ${sub?`<div class="stat-sub">${sub}</div>`:''}
  </div>`).join('');

  const alertImp=document.getElementById('alert-imp');
  const prob=impayes.length+attente.length;
  alertImp.style.display=prob>0?'block':'none';
  if(prob>0) alertImp.innerHTML=`<strong>Attention :</strong> ${prob} loyer(s) impayé(s) ou en attente ce mois.`;

  const in30=new Date(); in30.setDate(in30.getDate()+30);
  const in30s=in30.toISOString().split('T')[0];
  const expiring=S.locataires.filter(l=>l.fin&&l.fin>=today&&l.fin<=in30s);
  const alertBail=document.getElementById('alert-bail');
  alertBail.style.display=expiring.length?'block':'none';
  if(expiring.length) alertBail.innerHTML=`<strong>Baux expirant sous 30 jours :</strong> ${expiring.map(l=>l.nom+' ('+fDate(l.fin)+')').join(', ')}`;

  const recent=[...S.paiements].sort((a,b)=>(b.date||'').localeCompare(a.date||'')).slice(0,8);
  const tbody=document.getElementById('recent-payments');
  if(!recent.length){tbody.innerHTML='<tr><td colspan="5" class="empty-state">Aucun paiement enregistré</td></tr>';return;}
  tbody.innerHTML=recent.map(p=>`<tr>
    <td style="font-weight:600">${lNom(p.locId)}</td>
    <td style="color:var(--text2)">${lcNom(p.locId)}</td>
    <td style="font-family:var(--mono)">${fFCFA(p.montant)} FCFA</td>
    <td style="color:var(--text2)">${fMois(p.mois)}</td>
    <td>${badge(p.statut)}</td>
  </tr>`).join('');
}

