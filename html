function saveParams() {
  const nom = document.getElementById('param-nom').value.trim();
  const adr = document.getElementById('param-adresse').value.trim();
  if (!nom) return alert('Le nom est obligatoire.');
  S.config.nom = nom; S.config.adresse = adr; save();
  document.getElementById('topbar-name').textContent = nom;
  document.getElementById('auth-owner').textContent  = nom;
  alert('Informations enregistrées.');
}
function changePin() {
  const old = document.getElementById('param-old-pin').value;
  const nw  = document.getElementById('param-new-pin').value;
  const msg = document.getElementById('pin-msg');
  if (old!==S.config.pin) { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Ancien mot de passe incorrect.'; return; }
  if (!nw||nw.length<3)   { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Minimum 3 caractères.'; return; }
  S.config.pin=nw; save();
  document.getElementById('param-old-pin').value='';
  document.getElementById('param-new-pin').value='';
  msg.style.display='block'; msg.style.color='var(--green)'; msg.textContent='Mot de passe modifié.';
}
function exportData() {
  const blob = new Blob([JSON.stringify(S,null,2)],{type:'application/json'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href=url; a.download='gestiloc_'+new Date().toISOString().split('T')[0]+'.json'; a.click();
  URL.revokeObjectURL(url);
}
function importData(e) {
  const file=e.target.files[0]; const msg=document.getElementById('import-msg');
  if (!file) return;
  const r=new FileReader();
  r.onload=ev=>{
    try {
      const data=JSON.parse(ev.target.result);
      if (!data.chambres||!data.locataires||!data.paiements) throw new Error();
      if (!confirm('Remplacer toutes les données actuelles ?')) return;
      S=data; if(!S.config) S.config={nom:'LOKONON Paul',adresse:'Cotonou, Bénin',pin:DEFAULT_PIN,theme:'warm'};
      if(!S.config.pin) S.config.pin=DEFAULT_PIN;
      save(); msg.style.display='block'; msg.style.color='var(--green)';
      msg.textContent='Import réussi — '+S.chambres.length+' chambres, '+S.locataires.length+' locataires.';
      initApp();
    } catch(err) {
      msg.style.display='block'; msg.style.color='var(--red)';
      msg.textContent='Fichier invalide. Utilisez une sauvegarde GestiLoc.';
    }
  };
  r.readAsText(file); e.target.value='';
}
function resetAll() {
  if (!confirm('ATTENTION : toutes les données seront effacées.\n\nConfirmer la réinitialisation ?')) return;
  const {pin,nom,adresse,theme}=S.config;
  S={chambres:[],locataires:[],paiements:[],config:{pin,nom,adresse,theme}};
  save(); alert('Base de données réinitialisée.'); renderAll();
}

