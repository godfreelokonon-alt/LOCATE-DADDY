<!-- ══ JAVASCRIPT ════════════════════════════════════════════════ -->
<script>
'use strict';

// ── CONSTANTES ────────────────────────────────────────────────────
const SK = 'gestiloc_v4';
const DEFAULT_PIN = '1234';

// ── STATE ─────────────────────────────────────────────────────────
let S = { chambres:[], locataires:[], paiements:[], config:{ nom:'LOKONON Paul', adresse:'Cotonou, Bénin', pin:DEFAULT_PIN, theme:'warm' } };

// ── PERSISTENCE ───────────────────────────────────────────────────
function load() {
  try { const r = localStorage.getItem(SK); if (r) S = JSON.parse(r); } catch(e) {}
  S.chambres   = S.chambres   || [];
  S.locataires = S.locataires || [];
  S.paiements  = S.paiements  || [];
  S.config     = S.config     || {};
  S.config.nom     = S.config.nom     || 'LOKONON Paul';
  S.config.adresse = S.config.adresse || 'Cotonou, Bénin';
  S.config.pin     = S.config.pin     || DEFAULT_PIN;
  S.config.theme   = S.config.theme   || 'warm';

  if (!S.chambres.length) seedDemo();
}
function save() { try { localStorage.setItem(SK, JSON.stringify(S)); } catch(e) {} }
function uid()  { return Date.now() + Math.floor(Math.random()*9999); }
function mNow() { return new Date().toISOString().slice(0,7); }
function mPrev(m){ const d=new Date(m+'-01'); d.setMonth(d.getMonth()-1); return d.toISOString().slice(0,7); }

function seedDemo() {
  S.chambres = [
    {id:1,num:'Chambre 1',type:'Chambre simple',prix:20000,caution:40000,desc:''},
    {id:2,num:'Chambre 2',type:'Chambre simple',prix:20000,caution:40000,desc:''},
    {id:3,num:'Studio A', type:'Studio',         prix:35000,caution:70000,desc:'Avec salle de bain'},
  ];
  S.locataires = [
    {id:1,nom:'Kokou Amedji', tel:'97112233',piece:'CNI-0012',chambreId:1,date:'2024-01-15',fin:'2025-09-15',caution:40000,notes:''},
    {id:2,nom:'Fatou Diallo',  tel:'96223344',piece:'PASS-044',chambreId:3,date:'2024-03-01',fin:'2025-11-01',caution:70000,notes:''},
  ];
  const m=mNow(), pm=mPrev(m);
  S.paiements = [
    {id:1,locId:1,montant:20000,mois:pm,date:pm+'-02',statut:'paye',  notes:''},
    {id:2,locId:2,montant:35000,mois:pm,date:pm+'-03',statut:'paye',  notes:''},
    {id:3,locId:1,montant:20000,mois:m, date:'',       statut:'impaye',notes:''},
    {id:4,locId:2,montant:35000,mois:m, date:'',       statut:'en_attente',notes:''},
  ];
  save();
}

// ── HELPERS ───────────────────────────────────────────────────────
const cById  = id => S.chambres.find(c=>c.id==id)||null;
const lById  = id => S.locataires.find(l=>l.id==id)||null;
const cNom   = id => { const c=cById(id); return c?c.num:'-'; };
const lNom   = id => { const l=lById(id); return l?l.nom:'-'; };
const lcNom  = id => { const l=lById(id); return l?cNom(l.chambreId):'-'; };
const owner  = ()  => S.config.nom||'LOKONON Paul';
const addr   = ()  => S.config.adresse||'Cotonou, Bénin';

function fDate(s) { if(!s) return '-'; try { return new Date(s).toLocaleDateString('fr-FR'); } catch(e){ return s; } }
function fMois(m) { if(!m) return ''; try { return new Date(m+'-01').toLocaleDateString('fr-FR',{month:'long',year:'numeric'}); } catch(e){ return m; } }
function fFCFA(n) { return Number(n||0).toLocaleString('fr-FR'); }

function badge(statut) {
  if(statut==='paye')       return '<span class="badge b-ok">Payé</span>';
  if(statut==='en_attente') return '<span class="badge b-att">En attente</span>';
  return '<span class="badge b-ko">Impayé</span>';
}

// ── THEME ─────────────────────────────────────────────────────────
function setTheme(t) {
  S.config.theme = t;
  document.documentElement.setAttribute('data-theme', t);
  document.getElementById('pill-warm').classList.toggle('active', t==='warm');
  document.getElementById('pill-frost').classList.toggle('active', t==='frost');
  save();
}

// ── AUTH ──────────────────────────────────────────────────────────
function login() {
  const v = document.getElementById('pin-input').value;
  const err = document.getElementById('auth-error');
  if (v === S.config.pin) {
    err.style.display = 'none';
    document.getElementById('auth-screen').style.display = 'none';
    document.getElementById('main').style.display = 'flex';
    document.getElementById('bottom-nav').style.display = 'flex';
    initApp();
  } else {
    err.style.display = 'block';
    document.getElementById('pin-input').value = '';
  }
}
function logout() {
  document.getElementById('main').style.display = 'none';
  document.getElementById('bottom-nav').style.display = 'none';
  document.getElementById('auth-screen').style.display = 'flex';
  document.getElementById('pin-input').value = '';
}

// ── INIT ──────────────────────────────────────────────────────────
function initApp() {
  const d = new Date();
  document.getElementById('today-date').textContent = d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  document.getElementById('topbar-name').textContent = owner();
  document.getElementById('topbar-role').textContent = 'Propriétaire bailleur';
  document.getElementById('auth-owner').textContent = owner();
  document.getElementById('rapport-mois').value = mNow();
  document.getElementById('loyers-mois').value  = mNow();
  document.getElementById('param-nom').value     = S.config.nom;
  document.getElementById('param-adresse').value = S.config.adresse;
  setTheme(S.config.theme);
  renderAll();
}

// ── NAVIGATION ────────────────────────────────────────────────────
const PAGES = ['dashboard','chambres','locataires','loyers','historique','rapport','relances','parametres'];

function goPage(name, topBtn) {
  PAGES.forEach(p => {
    const el = document.getElementById('page-'+p);
    if (el) el.classList.toggle('active', p===name);
  });
  // bottom nav
  ['dashboard','chambres','locataires','loyers'].forEach(p => {
    const btn = document.getElementById('nav-'+p);
    if (btn) btn.classList.toggle('active', p===name);
  });
  const more = document.getElementById('nav-more');
  if (more) more.classList.toggle('active', ['historique','rapport','relances','parametres'].includes(name));
  // top nav
  document.querySelectorAll('.top-nav-btn').forEach(b => b.classList.remove('active'));
  if (topBtn) topBtn.classList.add('active');
  renderAll();
}

// ── MODAL ─────────────────────────────────────────────────────────
function openModal(id, data) {
  if (id==='modal-chambre') {
    document.getElementById('mc-title').textContent = data ? 'Modifier la chambre' : 'Ajouter une chambre';
    document.getElementById('c-num').value    = data?.num    || '';
    document.getElementById('c-type').value   = data?.type   || 'Chambre simple';
    document.getElementById('c-prix').value   = data?.prix   || '';
    document.getElementById('c-caution').value= data?.caution|| '';
    document.getElementById('c-desc').value   = data?.desc   || '';
    document.getElementById('c-id').value     = data?.id     || '';
  }
  if (id==='modal-locataire') {
    popChambresSelect();
    document.getElementById('ml-title').textContent = data ? 'Modifier le locataire' : 'Ajouter un locataire';
    document.getElementById('l-nom').value    = data?.nom    || '';
    document.getElementById('l-tel').value    = data?.tel    || '';
    document.getElementById('l-piece').value  = data?.piece  || '';
    document.getElementById('l-chambre').value= data?.chambreId || '';
    document.getElementById('l-date').value   = data?.date   || '';
    document.getElementById('l-fin').value    = data?.fin    || '';
    document.getElementById('l-caution').value= data?.caution|| '';
    document.getElementById('l-notes').value  = data?.notes  || '';
    document.getElementById('l-id').value     = data?.id     || '';
  }
  if (id==='modal-paiement') {
    popLocSelect();
    document.getElementById('mp-title').textContent = data ? 'Modifier le paiement' : 'Enregistrer un paiement';
    document.getElementById('p-loc').value    = data?.locId  || '';
    document.getElementById('p-montant').value= data?.montant|| '';
    document.getElementById('p-mois').value   = data?.mois   || mNow();
    document.getElementById('p-date').value   = data?.date   || new Date().toISOString().split('T')[0];
    document.getElementById('p-statut').value = data?.statut || 'paye';
    document.getElementById('p-notes').value  = data?.notes  || '';
    document.getElementById('p-id').value     = data?.id     || '';
    document.getElementById('recu-zone').style.display = 'none';
    document.getElementById('recu-zone').innerHTML = '';
    if (!data) autoMontant();
  }
  document.getElementById(id).classList.add('open');
}
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// close on overlay click
document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', e => { if(e.target===o) o.classList.remove('open'); }));

// ── SELECTS ───────────────────────────────────────────────────────
function popChambresSelect() {
  document.getElementById('l-chambre').innerHTML =
    S.chambres.map(c=>`<option value="${c.id}">${c.num} — ${fFCFA(c.prix)} FCFA</option>`).join('');
}
function popLocSelect() {
  document.getElementById('p-loc').innerHTML =
    S.locataires.map(l=>`<option value="${l.id}">${l.nom} (${cNom(l.chambreId)})</option>`).join('');
}
function autoMontant() {
  const l = lById(document.getElementById('p-loc').value);
  if (l) { const c=cById(l.chambreId); if(c) document.getElementById('p-montant').value=c.prix; }
}

// ── CRUD — CHAMBRES ───────────────────────────────────────────────
function saveChambre() {
  const num    = document.getElementById('c-num').value.trim();
  const type   = document.getElementById('c-type').value;
  const prix   = parseInt(document.getElementById('c-prix').value)||0;
  const caution= parseInt(document.getElementById('c-caution').value)||0;
  const desc   = document.getElementById('c-desc').value.trim();
  const eid    = document.getElementById('c-id').value;
  if (!num||!prix) return alert('Numéro et loyer obligatoires.');
  if (eid) {
    const i = S.chambres.findIndex(c=>c.id==eid);
    if (i>-1) S.chambres[i] = {...S.chambres[i], num, type, prix, caution, desc};
  } else {
    S.chambres.push({id:uid(), num, type, prix, caution, desc});
  }
  save(); closeModal('modal-chambre'); renderAll();
}
function editChambre(id)   { const c=cById(id); if(c) openModal('modal-chambre',c); }
function deleteChambre(id) {
  if (!confirm('Supprimer cette chambre ?')) return;
  S.chambres = S.chambres.filter(c=>c.id!=id); save(); renderAll();
}

// ── CRUD — LOCATAIRES ─────────────────────────────────────────────
function saveLocataire() {
  const nom    = document.getElementById('l-nom').value.trim();
  const tel    = document.getElementById('l-tel').value.trim();
  const piece  = document.getElementById('l-piece').value.trim();
  const cId    = document.getElementById('l-chambre').value;
  const date   = document.getElementById('l-date').value;
  const fin    = document.getElementById('l-fin').value;
  const caution= parseInt(document.getElementById('l-caution').value)||0;
  const notes  = document.getElementById('l-notes').value.trim();
  const eid    = document.getElementById('l-id').value;
  if (!nom||!cId) return alert('Nom et chambre obligatoires.');
  if (eid) {
    const i = S.locataires.findIndex(l=>l.id==eid);
    if (i>-1) S.locataires[i] = {...S.locataires[i], nom, tel, piece, chambreId:cId, date, fin, caution, notes};
  } else {
    S.locataires.push({id:uid(), nom, tel, piece, chambreId:cId, date, fin, caution, notes});
  }
  save(); closeModal('modal-locataire'); renderAll();
}
function editLocataire(id)   { const l=lById(id); if(l) openModal('modal-locataire',l); }
function deleteLocataire(id) {
  if (!confirm('Supprimer ce locataire ? Ses paiements seront conservés.')) return;
  S.locataires = S.locataires.filter(l=>l.id!=id); save(); renderAll();
}

// ── CRUD — PAIEMENTS ──────────────────────────────────────────────
function savePaiement() {
  const locId  = document.getElementById('p-loc').value;
  const montant= parseInt(document.getElementById('p-montant').value)||0;
  const mois   = document.getElementById('p-mois').value;
  const date   = document.getElementById('p-date').value;
  const statut = document.getElementById('p-statut').value;
  const notes  = document.getElementById('p-notes').value.trim();
  const eid    = document.getElementById('p-id').value;
  if (!locId||!montant||!mois) return alert('Locataire, montant et mois obligatoires.');
  if (eid) {
    const i = S.paiements.findIndex(p=>p.id==eid);
    if (i>-1) S.paiements[i] = {...S.paiements[i], locId, montant, mois, date, statut, notes};
  } else {
    S.paiements.push({id:uid(), locId, montant, mois, date, statut, notes});
  }
  save(); closeModal('modal-paiement'); renderAll();
}
function editPaiement(id)   { const p=S.paiements.find(x=>x.id==id); if(p) openModal('modal-paiement',p); }
function marquerPaye(id) {
  const p=S.paiements.find(x=>x.id==id);
  if(p){ p.statut='paye'; p.date=new Date().toISOString().split('T')[0]; }
  save(); renderAll();
}
function deletePaiement(id) {
  if (!confirm('Supprimer ce paiement ?')) return;
  S.paiements = S.paiements.filter(p=>p.id!=id); save(); renderAll();
}

// ── WHATSAPP ──────────────────────────────────────────────────────
function waRelance(lid) {
  const l=lById(lid); if(!l||!l.tel) return alert('Numéro WhatsApp non renseigné pour ce locataire.');
  const m = mNow();
  const moisStr = fMois(m);
  const c = cById(l.chambreId);
  const loyer = c ? fFCFA(c.prix)+' FCFA' : '';
  const msg = `Bonjour ${l.nom},\n\nNous vous rappelons que votre loyer de ${loyer} pour ${l.chambreId ? cNom(l.chambreId) : ''} — mois de ${moisStr} — est en attente de règlement.\n\nMerci de bien vouloir régulariser votre situation.\n\nCordialement,\n${owner()}`;
  window.open('https://wa.me/'+l.tel.replace(/\D/g,'')+'?text='+encodeURIComponent(msg), '_blank');
}

// ── QUITTANCE ─────────────────────────────────────────────────────
function buildQuittance(loc, moisStr, datePay, montant, ref, piece) {
  const c = cById(loc.chambreId);
  const loyer = c ? fFCFA(c.prix) : '-';
  const today = new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
  return `<div class="quittance-wrap">
    <div class="qt-band">
      <div>
        <div class="qt-owner-name">${owner()}</div>
        <div class="qt-owner-role">Propriétaire bailleur</div>
        <div class="qt-owner-addr">${addr()}</div>
      </div>
      <div>
        <div class="qt-doc-label">Document officiel</div>
        <div class="qt-doc-title">Quittance<br>de loyer</div>
        <div class="qt-ref">${ref}</div>
      </div>
    </div>
    <div class="qt-body">
      <div class="qt-section-label">Locataire</div>
      <div class="qt-locataire-block">
        <div class="qt-loc-name">${loc.nom}</div>
        <div class="qt-loc-meta">
          <span>${cNom(loc.chambreId)}</span>
          ${piece ? '<span>· Pièce : '+piece+'</span>' : ''}
          ${loc.tel ? '<span>· '+loc.tel+'</span>' : ''}
        </div>
      </div>
      <div class="qt-section-label">Détail du paiement</div>
      <div class="qt-details-grid">
        <div class="qt-detail-cell"><div class="qt-detail-key">Période couverte</div><div class="qt-detail-val">${moisStr}</div></div>
        <div class="qt-detail-cell"><div class="qt-detail-key">Date de paiement</div><div class="qt-detail-val">${datePay||'Non renseignée'}</div></div>
        <div class="qt-detail-cell"><div class="qt-detail-key">Loyer mensuel</div><div class="qt-detail-val">${loyer} FCFA</div></div>
        <div class="qt-detail-cell"><div class="qt-detail-key">Type de logement</div><div class="qt-detail-val">${c?c.type:'-'}</div></div>
      </div>
      <div class="qt-section-label">Montant reçu</div>
      <div class="qt-montant-block">
        <div class="qt-montant-label">Somme perçue par le propriétaire</div>
        <div><span class="qt-montant-val">${montant}</span><span class="qt-montant-cur">FCFA</span></div>
      </div>
      <div class="qt-signatures">
        <div class="qt-sig-box"><div class="qt-sig-label">Signature du locataire</div><div class="qt-sig-name">${loc.nom}</div></div>
        <div class="qt-sig-box"><div class="qt-sig-label">Signature du bailleur</div><div class="qt-sig-name">${owner()}</div></div>
      </div>
      <div class="qt-footer">
        <div class="qt-footer-left">Émis le ${today} — Ce document tient lieu de quittance définitive</div>
        <div class="qt-footer-badge">GestiLoc v4</div>
      </div>
    </div>
  </div>`;
}

function aperçuQuittance() {
  const lid=document.getElementById('p-loc').value;
  const montant=parseInt(document.getElementById('p-montant').value)||0;
  const mois=document.getElementById('p-mois').value;
  const date=document.getElementById('p-date').value;
  if (!lid||!montant||!mois) return;
  const loc=lById(lid); if(!loc) return;
  const zone=document.getElementById('recu-zone');
  zone.innerHTML = buildQuittance(loc, fMois(mois), date, fFCFA(montant), 'APERÇU', loc.piece);
  zone.style.display='block';
}

function showRecu(pid) {
  const p=S.paiements.find(x=>x.id==pid); if(!p) return;
  const loc=lById(p.locId); if(!loc) return;
  const ref='QT-'+String(pid).slice(-6).toUpperCase();
  document.getElementById('recu-full-content').innerHTML = buildQuittance(loc, fMois(p.mois), p.date, fFCFA(p.montant), ref, loc.piece);
  openModal('modal-recu', null);
}

