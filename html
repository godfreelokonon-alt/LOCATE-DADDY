      <button class="btn-ghost" onclick="goPage('parametres')" style="font-size:var(--fs-xs)">Paramètres</button>
      <button class="btn-ghost" onclick="logout()" style="font-size:var(--fs-xs)">Déconnexion</button>
    </div>
  </div>

  <!-- Top nav (desktop) -->
  <div class="top-nav" id="top-nav">
    <button class="top-nav-btn active" onclick="goPage('dashboard',this)">Tableau de bord</button>
    <button class="top-nav-btn" onclick="goPage('chambres',this)">Chambres</button>
    <button class="top-nav-btn" onclick="goPage('locataires',this)">Locataires</button>
    <button class="top-nav-btn" onclick="goPage('loyers',this)">Loyers</button>
    <button class="top-nav-btn" onclick="goPage('historique',this)">Historique</button>
    <button class="top-nav-btn" onclick="goPage('rapport',this)">Rapport</button>
    <button class="top-nav-btn" onclick="goPage('relances',this)">Relances</button>
    <button class="top-nav-btn" onclick="goPage('parametres',this)">Paramètres</button>
  </div>

  <!-- Content -->
  <div class="content">

    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div id="alert-imp" class="alert alert-red" style="display:none"></div>
      <div id="alert-bail" class="alert alert-amber" style="display:none"></div>
