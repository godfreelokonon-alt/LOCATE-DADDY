      <td class="hide-mobile" style="color:var(--text3);font-size:var(--fs-xs)">${p.date||'-'}</td>
      <td>${badge(p.statut)}</td>
      <td><div style="display:flex;gap:4px;flex-wrap:wrap">
        ${act}
        <button class="btn-edit" onclick="editPaiement(${p.id})">Modifier</button>
        <button class="btn-danger" onclick="deletePaiement(${p.id})">Sup.</button>
      </div></td>
    </tr>`;
  }).join('');
}

// ── HISTORIQUE ────────────────────────────────────────────────────
function goHistorique(lid) {
  goPage('historique');
  const sel=document.getElementById('hist-select');
  sel.innerHTML='<option value="">— Choisir —</option>'+S.locataires.map(l=>`<option value="${l.id}">${l.nom}</option>`).join('');
  sel.value=lid;
  renderHistorique();
}
function renderHistorique() {
  const sel=document.getElementById('hist-select');
  sel.innerHTML='<option value="">— Choisir un locataire —</option>'+S.locataires.map(l=>`<option value="${l.id}">${l.nom}</option>`).join('');
  const lid=sel.value;
  const div=document.getElementById('hist-content');
  if(!lid){div.innerHTML='<div class="empty-state">Sélectionnez un locataire pour voir son historique.</div>';return;}
  const loc=lById(lid); if(!loc){div.innerHTML='';return;}
  const c=cById(loc.chambreId);
  const total=S.paiements.filter(p=>p.locId==lid&&p.statut==='paye').reduce((s,p)=>s+p.montant,0);
  const ps=S.paiements.filter(p=>p.locId==lid).sort((a,b)=>(b.mois||'').localeCompare(a.mois||''));
  div.innerHTML=`
    <div class="loc-info-card">
      <div><div class="li-label">Nom</div><div class="li-val">${loc.nom}</div></div>
      <div><div class="li-label">Téléphone</div><div class="li-val">${loc.tel||'-'}</div></div>
      <div><div class="li-label">Chambre</div><div class="li-val">${c?c.num:'-'}</div></div>
      <div><div class="li-label">Loyer mensuel</div><div class="li-val">${c?fFCFA(c.prix)+' FCFA':'-'}</div></div>
      <div><div class="li-label">Entrée</div><div class="li-val">${fDate(loc.date)}</div></div>
      <div><div class="li-label">Fin de bail</div><div class="li-val">${fDate(loc.fin)}</div></div>
      <div><div class="li-label">Caution versée</div><div class="li-val">${loc.caution?fFCFA(loc.caution)+' FCFA':'-'}</div></div>
      <div><div class="li-label">Total encaissé</div><div class="li-val" style="color:var(--green)">${fFCFA(total)} FCFA</div></div>
    </div>
    <div class="table-wrap">
      <table><thead><tr><th>Mois</th><th>Montant</th><th>Date</th><th>Statut</th><th>Quittance</th></tr></thead>
      <tbody>${!ps.length?'<tr><td colspan="5" class="empty-state">Aucun paiement</td></tr>':ps.map(p=>`<tr>
        <td>${fMois(p.mois)}</td>
        <td style="font-family:var(--mono)">${fFCFA(p.montant)} FCFA</td>
        <td style="color:var(--text2)">${p.date||'-'}</td>
        <td>${badge(p.statut)}</td>
        <td>${p.statut==='paye'?`<button class="btn-info" onclick="showRecu(${p.id})">Voir</button>`:'—'}</td>
      </tr>`).join('')}</tbody></table>
    </div>`;
  sel.value=lid;
}

// ── RAPPORT ───────────────────────────────────────────────────────
function renderRapport() {
  const mois=document.getElementById('rapport-mois').value;
  if(!mois){document.getElementById('rapport-content').innerHTML='<div class="empty-state">Sélectionnez un mois.</div>';return;}
  const moisStr=fMois(mois);
  const ps=S.paiements.filter(p=>p.mois===mois);
  const payes=ps.filter(p=>p.statut==='paye');
  const impayes=ps.filter(p=>p.statut==='impaye');
  const attente=ps.filter(p=>p.statut==='en_attente');
  const totalPercu=payes.reduce((s,p)=>s+p.montant,0);
  const totalImp=impayes.reduce((s,p)=>s+p.montant,0);
  const totalAtt=attente.reduce((s,p)=>s+p.montant,0);
  const attendu=S.locataires.reduce((s,l)=>{ const c=cById(l.chambreId); return s+(c?c.prix:0); },0);
  const taux=attendu>0?Math.round((totalPercu/attendu)*100):0;
  const occIds=[...new Set(S.locataires.map(l=>l.chambreId))].filter(id=>S.chambres.find(c=>c.id==id));

  document.getElementById('rapport-content').innerHTML=`
    <div class="rapport-section">
      <h3>Synthèse — ${moisStr}</h3>
      <div class="rapport-row"><span class="rapport-label">Loyers attendus</span><span class="rapport-val">${fFCFA(attendu)} FCFA</span></div>
      <div class="rapport-row"><span class="rapport-label">Loyers perçus</span><span class="rapport-val g">${fFCFA(totalPercu)} FCFA</span></div>
      <div class="rapport-row"><span class="rapport-label">En attente de règlement</span><span class="rapport-val a">${fFCFA(totalAtt)} FCFA</span></div>
      <div class="rapport-row"><span class="rapport-label">Impayés</span><span class="rapport-val r">${fFCFA(totalImp)} FCFA</span></div>
      <div class="rapport-row total"><span class="rapport-label">Taux de recouvrement</span><span class="rapport-val ${taux>=80?'g':'r'}">${taux} %</span></div>
    </div>
    <div class="rapport-section">
      <h3>Détail par locataire</h3>
      ${S.locataires.map(l=>{
        const c=cById(l.chambreId);
        const p=ps.find(x=>x.locId==l.id);
        const st=p?badge(p.statut):'<span class="badge b-ko">Non enregistré</span>';
        const mt=p?fFCFA(p.montant)+' FCFA':(c?fFCFA(c.prix)+' FCFA':'—');
        return `<div class="rapport-row"><span class="rapport-label">${l.nom} — ${cNom(l.chambreId)}</span><span style="display:flex;align-items:center;gap:8px">${st}<span class="rapport-val">${mt}</span></span></div>`;
      }).join('')}
    </div>
    <div class="rapport-section">
      <h3>Occupation</h3>
      <div class="rapport-row"><span class="rapport-label">Chambres totales</span><span class="rapport-val">${S.chambres.length}</span></div>
      <div class="rapport-row"><span class="rapport-label">Occupées</span><span class="rapport-val g">${occIds.length}</span></div>
      <div class="rapport-row"><span class="rapport-label">Libres</span><span class="rapport-val b">${S.chambres.length-occIds.length}</span></div>
    </div>
    <div style="text-align:right;font-size:var(--fs-xs);color:var(--text3);margin-top:8px">
      Rapport GestiLoc — ${owner()} — ${new Date().toLocaleDateString('fr-FR')}
    </div>`;
}

// ── RELANCES ──────────────────────────────────────────────────────
function renderRelances() {
  const m=mNow(), div=document.getElementById('relances-content');
  const aRelancer=S.locataires.filter(l=>{ const p=S.paiements.find(x=>x.locId==l.id&&x.mois===m); return !p||p.statut!=='paye'; });
  if(!aRelancer.length){ div.innerHTML='<div class="empty-state" style="color:var(--green)">Tous les locataires sont à jour ce mois-ci.</div>'; return; }
  const ml=fMois(m);
  div.innerHTML=`<div style="font-size:var(--fs-sm);color:var(--text2);margin-bottom:1rem">${aRelancer.length} locataire(s) à relancer pour ${ml}</div>`+
    aRelancer.map(l=>{
      const c=cById(l.chambreId);
      const p=S.paiements.find(x=>x.locId==l.id&&x.mois===m);
      const st=p?badge(p.statut):'<span class="badge b-ko">Non enregistré</span>';
      return `<div class="relance-card">
        <div>
          <div class="relance-nom">${l.nom}</div>
          <div class="relance-detail">${cNom(l.chambreId)} — ${c?fFCFA(c.prix)+' FCFA':''} — Tél : ${l.tel||'non renseigné'}</div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          ${st}
          <button class="btn-wa" onclick="waRelance(${l.id})">WhatsApp</button>
          <button class="btn-add" onclick="marquerPayeRelance(${l.id})">Marquer payé</button>
        </div>
      </div>`;
    }).join('');
}

function marquerPayeRelance(lid) {
  const m=mNow(), loc=lById(lid), c=loc?cById(loc.chambreId):null;
  const p=S.paiements.find(x=>x.locId==lid&&x.mois===m);
  if(p){ p.statut='paye'; p.date=new Date().toISOString().split('T')[0]; }
  else if(loc&&c) S.paiements.push({id:uid(),locId:lid,montant:c.prix,mois:m,date:new Date().toISOString().split('T')[0],statut:'paye',notes:''});
  save(); renderAll();
}

// ── BOOT ──────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  load();
  document.documentElement.setAttribute('data-theme', S.config.theme||'warm');
  document.getElementById('auth-owner').textContent = S.config.nom||'LOKONON Paul';
  document.getElementById('pin-input').addEventListener('keydown', e => { if(e.key==='Enter') login(); });
  // hide bottom-nav until logged in
  document.getElementById('bottom-nav').style.display = 'none';
});
</script>
</body>
