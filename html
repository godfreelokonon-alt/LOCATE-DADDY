function printViaIframe(html, css, title) {
  const frame = document.getElementById('print-frame');
  frame.style.display = 'block';
  const doc = frame.contentDocument || frame.contentWindow.document;
  doc.open();
  doc.write(`<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><title>${title}</title><link rel="preconnect" href="https://fonts.googleapis.com"><link href="${PRINT_FONTS}" rel="stylesheet"><style>${css}</style></head><body>${html}</body></html>`);
  doc.close();
  frame.onload = () => {
    setTimeout(() => {
      frame.contentWindow.focus();
      frame.contentWindow.print();
      setTimeout(() => { frame.style.display='none'; }, 1000);
    }, 500);
  };
}

function printQuittance() {
