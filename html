      </div>
      <div class="table-wrap">
        <table><thead><tr><th>Locataire</th><th>Chambre</th><th>Montant</th><th>Mois</th><th>Statut</th></tr></thead>
        <tbody id="recent-payments"></tbody></table>
      </div>
    </div>

    <!-- CHAMBRES -->
    <div class="page" id="page-chambres">
      <div class="section-header">
        <span class="section-title">Mes chambres</span>
        <button class="btn-add" onclick="openModal('modal-chambre',null)">+ Ajouter</button>
